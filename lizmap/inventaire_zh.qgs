      <mapTip>&lt;div class="container popup_lizmap_dd form-horizontal" style="width:100%;">
    
    &lt;div class="before-tabs">
      
                        [%
                        concat(
                            '&lt;div class="control-group ',
                            CASE
                                WHEN "pk" IS NULL OR trim("pk") = ''
                                    THEN ' control-has-empty-value '
                                ELSE ''
                            END,
                            '">',
                            '    &lt;label ',
                            '       id="dd_jforms_view_edition_pk_label" ',
                            '       class="control-label jforms-label" ',
                            '       for="dd_jforms_view_edition_pk" >',
                            '    Identifiant',
                            '    &lt;/label>',
                            '    &lt;div class="controls">',
                            '        &lt;span ',
                            '            id="dd_jforms_view_edition_pk" ',
                            '            class="jforms-control-input" ',
                            '        >',
                                        "pk",
                            '        &lt;/span>',
                            '    &lt;/div>',
                            '&lt;/div>'
                        )
                        %]
    
      
                        [%
                        concat(
                            '&lt;div class="control-group ',
                            CASE
